#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: ./r2decomp [options] <binary>

Generates a single combined pseudo-C export for every discovered function.
ELF architecture is detected automatically. Raw Cortex-M firmware is detected
from its vector table (including the common 0x4000-byte updater header).

options:
  --decompiler pdg|pdc       Pseudo-C backend (default: pdg)
  --analysis-mode aa|aaa     radare2 analysis depth (default: aa)
  --output-dir DIR           Output directory (default: current directory)
  --arch auto|arm|thumb|armv7l|aarch64
                              Override architecture detection (default: auto)
  --bits auto|16|32|64       Override bitness detection (default: auto)
  --base auto|ADDRESS        Raw-binary load address (default: auto)
  --raw                      Treat input as a flat binary, not an ELF
  --function NAME@ADDRESS    Name and include a known function (repeatable)

For an unrecognized raw binary, specify --raw --arch --bits --base explicitly.
EOF
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

decompiler="pdg"
analysis_mode="aa"
output_dir=""
arch="auto"
bits="auto"
base="auto"
force_raw=0
known_functions=()
positionals=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --decompiler)
      if [[ $# -lt 2 ]]; then
        echo "error: --decompiler requires a value" >&2
        exit 1
      fi
      decompiler="$2"
      shift 2
      ;;
    --decompiler=*)
      decompiler="${1#*=}"
      shift
      ;;
    --analysis-mode)
      if [[ $# -lt 2 ]]; then
        echo "error: --analysis-mode requires a value" >&2
        exit 1
      fi
      analysis_mode="$2"
      shift 2
      ;;
    --analysis-mode=*)
      analysis_mode="${1#*=}"
      shift
      ;;
    --output-dir)
      if [[ $# -lt 2 ]]; then
        echo "error: --output-dir requires a value" >&2
        exit 1
      fi
      output_dir="$2"
      shift 2
      ;;
    --output-dir=*)
      output_dir="${1#*=}"
      shift
      ;;
    --arch)
      if [[ $# -lt 2 ]]; then
        echo "error: --arch requires a value" >&2
        exit 1
      fi
      arch="$2"
      shift 2
      ;;
    --arch=*)
      arch="${1#*=}"
      shift
      ;;
    --bits)
      if [[ $# -lt 2 ]]; then
        echo "error: --bits requires a value" >&2
        exit 1
      fi
      bits="$2"
      shift 2
      ;;
    --bits=*)
      bits="${1#*=}"
      shift
      ;;
    --base)
      if [[ $# -lt 2 ]]; then
        echo "error: --base requires a value" >&2
        exit 1
      fi
      base="$2"
      shift 2
      ;;
    --base=*)
      base="${1#*=}"
      shift
      ;;
    --raw)
      force_raw=1
      shift
      ;;
    --function)
      if [[ $# -lt 2 ]]; then
        echo "error: --function requires NAME@ADDRESS" >&2
        exit 1
      fi
      known_functions+=("$2")
      shift 2
      ;;
    --function=*)
      known_functions+=("${1#*=}")
      shift
      ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        positionals+=("$1")
        shift
      done
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      positionals+=("$1")
      shift
      ;;
  esac
done

if [[ ${#positionals[@]} -ne 1 ]]; then
  usage >&2
  exit 1
fi

case "$decompiler" in
  pdg|pdc)
    ;;
  *)
    echo "error: unsupported --decompiler mode: $decompiler" >&2
    exit 1
    ;;
esac

case "$analysis_mode" in
  aa|aaa)
    ;;
  *)
    echo "error: unsupported --analysis-mode: $analysis_mode" >&2
    exit 1
    ;;
esac

case "$arch" in
  auto|arm|thumb|armv7l|aarch64)
    ;;
  *)
    echo "error: unsupported --arch: $arch" >&2
    exit 1
    ;;
esac

case "$bits" in
  auto|16|32|64)
    ;;
  *)
    echo "error: unsupported --bits: $bits" >&2
    exit 1
    ;;
esac

for known_function in "${known_functions[@]}"; do
  if ! [[ "$known_function" =~ ^[A-Za-z_][A-Za-z0-9_.-]*@(0[xX][0-9a-fA-F]+|[0-9]+)$ ]]; then
    echo "error: --function must be NAME@ADDRESS: $known_function" >&2
    exit 1
  fi
done

elf_input="${positionals[0]}"
if [[ ! -f "$elf_input" ]]; then
  echo "error: input not found: $elf_input" >&2
  exit 1
fi

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "error: missing required tool: $1" >&2
    exit 1
  }
}

need_r2() {
  if command -v r2 >/dev/null 2>&1; then
    return
  fi

  cat >&2 <<'EOF'
error: radare2 (r2) is not installed

install it with:
  git clone https://github.com/radareorg/radare2
  cd radare2 ; sys/install.sh
EOF
  exit 1
}

need_r2pm() {
  command -v r2pm >/dev/null 2>&1 || {
    cat >&2 <<'EOF'
error: r2pm is required to install the r2ghidra plugin for pdg output

install radare2 with:
  git clone https://github.com/radareorg/radare2
  cd radare2 ; sys/install.sh
EOF
    exit 1
  }
}

r2pm_pdg_prereqs() {
  local missing=()
  local tool
  for tool in git make gcc g++ pkg-config patch unzip wget; do
    if ! command -v "$tool" >/dev/null 2>&1; then
      missing+=("$tool")
    fi
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "error: pdg needs build tools for the r2ghidra install path: ${missing[*]}" >&2
    echo "install them first, then rerun with pdg or use --decompiler pdc" >&2
    exit 1
  fi
}

r2_has_pdg() {
  local target="$1"
  local probe=""
  probe="$(r2 -q -e scr.color=0 -e scr.interactive=false -c 'pdg?; q' "$target" 2>&1 || true)"
  [[ "$probe" == *"Native Ghidra decompiler plugin"* ]] && [[ "$probe" != *"install the plugin"* ]]
}

ensure_r2_decompiler() {
  local target="$1"

  if [[ "$decompiler" == "pdc" ]]; then
    return
  fi

  need_r2pm
  r2pm_pdg_prereqs
  if r2_has_pdg "$target"; then
    return
  fi

  echo "info: installing r2ghidra with r2pm -ci r2ghidra" >&2
  if ! r2pm -ci r2ghidra; then
    echo "info: initializing r2pm package database and retrying r2ghidra install" >&2
    r2pm -U
    r2pm -ci r2ghidra
  fi

  if ! r2_has_pdg "$target"; then
    echo "error: requested pdg output, but r2ghidra is still unavailable after installation" >&2
    exit 1
  fi
}

need file
need python3
need_r2
ensure_r2_decompiler "$elf_input"

file_desc="$(file -b "$elf_input")"
is_elf=0
if [[ "$file_desc" == ELF* ]] && [[ "$force_raw" -eq 0 ]]; then
  is_elf=1
fi

r2_asm_arch=""
r2_asm_bits=""
r2_base=""
input_kind="ELF"

normalize_arch() {
  case "$1" in
    arm) echo "arm:32" ;;
    thumb) echo "arm:16" ;;
    armv7l) echo "arm:32" ;;
    aarch64) echo "arm:64" ;;
    *) echo ":" ;;
  esac
}

if [[ "$is_elf" -eq 1 ]]; then
  case "$file_desc" in
    *AArch64*|*ARM64*|*arm64*) r2_asm_arch="arm"; r2_asm_bits="64" ;;
    *ARM*) r2_asm_arch="arm"; r2_asm_bits="32" ;;
  esac
else
  input_kind="raw"
  # A Cortex-M vector begins with an SRAM stack pointer and an odd reset
  # handler. Updater images often prepend a 0x4000-byte metadata header.
  vector_offset=""
  for candidate in 0 16384; do
    words="$(od -An -N8 -j "$candidate" -tu4 "$elf_input" 2>/dev/null || true)"
    read -r stack_pointer reset_handler <<<"$words"
    if [[ "$stack_pointer" =~ ^[0-9]+$ ]] && [[ "$reset_handler" =~ ^[0-9]+$ ]] \
       && (( (stack_pointer & 0xff000000) == 0x20000000 )) \
       && (( (reset_handler & 1) == 1 )) \
       && (( (reset_handler & 0xff000000) == 0x08000000 )); then
      vector_offset="$candidate"
      break
    fi
  done
  if [[ -n "$vector_offset" ]]; then
    r2_asm_arch="arm"
    r2_asm_bits="16"
    if [[ "$vector_offset" -eq 16384 ]]; then
      r2_base="0x08008000"
    else
      r2_base="0x08000000"
    fi
  fi
fi

if [[ "$arch" != auto ]]; then
  IFS=: read -r r2_asm_arch r2_asm_bits <<<"$(normalize_arch "$arch")"
fi
if [[ "$bits" != auto ]]; then
  r2_asm_bits="$bits"
fi
if [[ "$base" != auto ]]; then
  if ! [[ "$base" =~ ^(0[xX][0-9a-fA-F]+|[0-9]+)$ ]]; then
    echo "error: --base must be a decimal or hexadecimal address: $base" >&2
    exit 1
  fi
  r2_base="$base"
fi

if [[ "$is_elf" -eq 0 ]] && [[ -z "$r2_asm_arch" || -z "$r2_asm_bits" || -z "$r2_base" ]]; then
  echo "error: unable to identify raw input: $elf_input" >&2
  echo "file says: $file_desc" >&2
  echo "use --raw --arch thumb|arm|aarch64 --bits 16|32|64 --base ADDRESS" >&2
  exit 1
fi

elf_base="$(basename "$elf_input")"
if [[ -z "$output_dir" ]]; then
  output_dir="$(pwd)"
fi
mkdir -p "$output_dir"
if [[ ! -w "$output_dir" ]]; then
  echo "error: output directory is not writable: $output_dir" >&2
  exit 1
fi

funcs_json="${output_dir}/${elf_base}.functions.json"
if [[ "$decompiler" == "pdg" ]]; then
  r2_batch="${output_dir}/${elf_base}.decompile-all-pdg.r2"
  pseudo_c_output="${output_dir}/${elf_base}.pdg.c"
else
  r2_batch="${output_dir}/${elf_base}.decompile-all-pdc.r2"
  pseudo_c_output="${output_dir}/${elf_base}.pdc.c"
fi
analysis_r2_opts=(-q -e bin.cache=true)
if [[ "$is_elf" -eq 0 ]]; then
  # Do not add -n here. Recent radare2 releases can crash when -n is combined
  # with a mapped raw ARM image; the normal raw loader is both sufficient and
  # the invocation used by the original Thumb analysis scripts.
  analysis_r2_opts+=(-a "$r2_asm_arch" -b "$r2_asm_bits" -m "$r2_base")
elif [[ -n "$r2_asm_arch" ]]; then
  analysis_r2_opts+=(-e "asm.arch=${r2_asm_arch}" -e "asm.bits=${r2_asm_bits}")
fi
analysis_commands="$analysis_mode"
for known_function in "${known_functions[@]}"; do
  known_name="${known_function%@*}"
  known_address="${known_function##*@}"
  analysis_commands+="; s ${known_address}; af; afn ${known_name}"
done
analysis_commands+="; aflj; q"
r2 "${analysis_r2_opts[@]}" -c "$analysis_commands" "$elf_input" > "$funcs_json"

python3 - "$funcs_json" "$r2_batch" "$decompiler" "$analysis_mode" "$r2_asm_arch" "$r2_asm_bits" "$r2_base" "${known_functions[@]}" <<'PY'
import json
import sys
from pathlib import Path

funcs_path = Path(sys.argv[1])
batch_path = Path(sys.argv[2])
asm_arch = sys.argv[5]
asm_bits = sys.argv[6]
base = sys.argv[7]
known_functions = sys.argv[8:]

data = json.loads(funcs_path.read_text() or "[]")

with batch_path.open("w") as fh:
    fh.write("e scr.color=0\n")
    fh.write("e scr.interactive=false\n")
    fh.write("e bin.cache=true\n")
    if asm_arch:
        fh.write(f"e asm.arch={asm_arch}\n")
    if asm_bits:
        fh.write(f"e asm.bits={asm_bits}\n")
    fh.write(f"{sys.argv[4]}\n")
    for spec in known_functions:
        name, address = spec.rsplit("@", 1)
        fh.write(f"s {address}\n")
        fh.write("af\n")
        fh.write(f"afn {name}\n")
    fh.write(f"?e // pseudo-c export for all discovered functions via {sys.argv[3]}\n")
    fh.write(f"?e // analysis mode: {sys.argv[4]}\n")
    for fn in data:
        offset = fn.get("offset")
        if offset is None:
            offset = fn.get("addr")
        if offset is None:
            offset = fn.get("vaddr")
        name = fn.get("name", "sub")
        size = fn.get("size", 0)
        if offset is None:
            continue
        fh.write("?e \n")
        fh.write(f"?e // ----- BEGIN {name} size={size} @ 0x{offset:x} -----\n")
        fh.write(f"s 0x{offset:x}\n")
        fh.write(f"{sys.argv[3]}\n")
        fh.write(f"?e // ----- END {name} -----\n")
    fh.write("q\n")
PY

final_r2_opts=(-q -e bin.cache=true -e scr.color=0)
if [[ "$is_elf" -eq 0 ]]; then
  final_r2_opts+=(-a "$r2_asm_arch" -b "$r2_asm_bits" -m "$r2_base")
elif [[ -n "$r2_asm_arch" ]]; then
  final_r2_opts+=(-e "asm.arch=${r2_asm_arch}" -e "asm.bits=${r2_asm_bits}")
fi
r2 "${final_r2_opts[@]}" -i "$r2_batch" "$elf_input" > "$pseudo_c_output"

echo "wrote:"
echo "  input: $input_kind (arch=${r2_asm_arch:-auto}, bits=${r2_asm_bits:-auto}${r2_base:+, base=$r2_base})"
echo "  $funcs_json"
echo "  $r2_batch"
echo "  $pseudo_c_output"
